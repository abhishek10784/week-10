#include <stdio.h>
#include <stdlib.h>
int main() {
int n, i, *a, *b;
printf("25331A05H2");
printf("\nEnter size: ");
scanf("%d", &n);
a = (int*) malloc(n * sizeof(int));
b = (int*) calloc(n, sizeof(int));
if (a == NULL || b == NULL) {
printf("Memory allocation failed\n");
return 1;
}
printf("Enter %d values for malloc array:\n", n);
for (i = 0; i < n; i++)
scanf("%d", &a[i]);
printf("malloc array: ");
for (i = 0; i < n; i++) printf("%d ", a[i]);
printf("\ncalloc array (default 0): ");
for (i = 0; i < n; i++) printf("%d ", b[i]);
printf("\n");
free(a); free(b);
return 0;
}
