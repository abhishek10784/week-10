#include <stdio.h>
#include <stdlib.h>
int main() {
int *p, i;
printf("25331A05H2");
p = (int*) malloc(3 * sizeof(int));
for (i = 0; i < 3; i++) p[i] = (i + 1) * 10;
printf("Before realloc: ");
for (i = 0; i < 3; i++) printf("%d ", p[i]);
p = (int*) realloc(p, 5 * sizeof(int));
p[3] = 40; p[4] = 50;
printf("\nAfter realloc: ");
for (i = 0; i < 5; i++) printf("%d ", p[i]);
printf("\n");
free(p);
p = NULL;
return 0;
}
